import mlflow
import pandas as pd
import re

print("=" * 80)
print("EVALUATING GRAPHRAG WITH MLFLOW")
print("=" * 80)

# 1. Create an evaluation dataset with ONLY the exact question the user just asked!
eval_df = pd.DataFrame([
    {"request": USER_QUERY}
])

# 2. Define the Full Pipeline (Retriever + LLM) for MLflow
def evaluate_graphrag_pipeline(row):
    question = row["request"]
    
    # --- A. RETRIEVER STAGE ---
    q_keywords = get_keywords(question)
    scores = []
    for n, attr in KG.nodes(data=True):
        overlap = len(q_keywords.intersection(get_keywords(attr.get('title', ''))))
        if overlap > 0: scores.append((n, overlap))
            
    scores.sort(key=lambda x: x[1], reverse=True)
    start_nodes = [s[0] for s in scores[:3]]
    
    retrieved_edges = []
    visited = set()
    for current_node in start_nodes:
        for neighbor in KG.successors(current_node):
            if (current_node, neighbor) not in visited:
                visited.add((current_node, neighbor))
                edge_data = KG.get_edge_data(current_node, neighbor)
                retrieved_edges.append((current_node, neighbor, edge_data))
                
    # --- B. CONTEXT BUILDER ---
    context_chunks = []
    
    # CRITICAL FIX: Add the raw text so the MLflow Judge sees the real data!
    for n in start_nodes:
        title = str(KG.nodes[n].get('title', n))
        raw_content = str(KG.nodes[n].get('content', ''))
        if raw_content:
            context_chunks.append({
                "doc_uri": f"{n}_raw_text",
                "content": f"DOCUMENT TITLE: {title}\nDOCUMENT CONTENT:\n{raw_content}"
            })
            
    edge_lines = []
    for u, v, attr in retrieved_edges[:10]:
        src_title = str(KG.nodes[u].get('title', u))
        tgt_title = str(KG.nodes[v].get('title', v))
        if "doc:" in tgt_title:
            tgt_title = tgt_title.split(".")[-1].replace("WebHome", "").strip()
            tgt_title = re.sub(r'[^a-zA-Z\s]', '', tgt_title).strip()
            if not tgt_title: tgt_title = "an external document"
            
        predicate = str(attr.get('predicate', 'related to')).replace("_", " ")
        fact = f"{src_title} {predicate} {tgt_title}."
        edge_lines.append(fact)
        context_chunks.append({"doc_uri": f"{u}_to_{v}", "content": fact})
        
    full_node_context = "\n".join([c["content"] for c in context_chunks if "DOCUMENT CONTENT" in c["content"]])
    graph_edge_context = "\n".join(edge_lines)
    
    # --- C. LLM ANSWER GENERATION ---
    final_prompt = f"Question:\n{question}\n\nRAW DOCUMENT TEXT:\n{full_node_context}\n\nGRAPH RELATIONSHIPS:\n{graph_edge_context}"
    
    try:
        response_obj = llm.invoke([
            ("system", SYSTEM_PROMPT),
            ("human", final_prompt)
        ])
        llm_response = response_obj.content.strip()
    except Exception:
        llm_response = "Error calling LLM."

    # Return exactly what Databricks MLflow expects to grade
    return pd.Series({
        "retrieved_context": context_chunks,
        "response": llm_response
    })

# Apply the full pipeline to our single evaluation question
print(f"Evaluating Question: '{USER_QUERY}'")
print("Running Full GraphRAG Pipeline (This takes a moment)...")
pipeline_results = eval_df.apply(evaluate_graphrag_pipeline, axis=1)
eval_df_final = pd.concat([eval_df, pipeline_results], axis=1)

# 3. Run MLflow evaluate
print("\nStarting MLflow Run to grade the Retriever and Response...")
with mlflow.start_run(run_name="GraphRAG_Official_Evaluation"):
    eval_data = eval_df_final.to_dict(orient="records")
    try:
        results = mlflow.evaluate(
            data=eval_data,
            model_type="databricks-agent", 
            evaluator_config={
                "databricks-agent": {
                    # Now it will grade both the Context AND your Final Answer!
                    "metrics": ["chunk_relevance", "relevance_to_query"] 
                }
            }
        )
        print("=" * 80)
        print("MLFLOW EVALUATION COMPLETE")
        print("=" * 80)
        display(results.tables["eval_results"])
    except Exception as e:
        print(f"MLflow Evaluation Failed: {e}")
