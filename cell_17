# 1. Build Readable Context from Graph Edges
# ----------------------------------------------------------
context_lines = []

for idx, (u, v, attr) in enumerate(retrieved_edges, 1):
    src_title = str(KG.nodes[u].get('title', u))
    tgt_title = str(KG.nodes[v].get('title', v))
    
    # Clean up the predicate (e.g. 'owned_and_maintained_by' -> 'owned and maintained by')
    predicate = str(attr.get('predicate', 'related to')).replace("_", " ")
    
    # We construct the clean sentence exactly as recommended in your PDF
    structured_fact = f"{src_title} {predicate} {tgt_title}."
    
    # We also include the original XML sentence for maximum LLM accuracy!
    original_sentence = attr.get('sentence', '')
    
    # Format: 1. Fact. (Evidence: original sentence)
    context_lines.append(f"{idx}. {structured_fact} (Evidence: {original_sentence})")

# Join all lines into one big context block
GRAPH_CONTEXT = "\n\n".join(context_lines)

print("Constructed Knowledge Graph Context:")
print("-" * 80)
print(GRAPH_CONTEXT[:1000] + "...\n[Context Truncated for Display]")
print("-" * 80)
print()

