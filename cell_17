# 1. Get the Raw Text of the Start Nodes!
# ----------------------------------------------------------
node_texts = []
for n in start_nodes:
    title = KG.nodes[n].get('title', n)
    # Pull the entire raw XML content from the node
    raw_content = KG.nodes[n].get('content', '')
    node_texts.append(f"DOCUMENT TITLE: {title}\nDOCUMENT CONTENT:\n{raw_content}")

FULL_NODE_CONTEXT = "\n\n".join(node_texts)

# ----------------------------------------------------------
# 2. Build Readable Context from Graph Edges (with ID cleanup)
# ----------------------------------------------------------
edge_lines = []
for idx, (u, v, attr) in enumerate(retrieved_edges, 1):
    src_title = str(KG.nodes[u].get('title', u))
    tgt_title = str(KG.nodes[v].get('title', v))
    
    # NEW: Aggressively clean up missing titles that are just raw 'doc:' IDs
    if "doc:" in tgt_title:
        # Extract the last part of the ID string
        tgt_title = tgt_title.split(".")[-1].replace("WebHome", "").strip()
        # Keep only letters and spaces using Regex
        tgt_title = re.sub(r'[^a-zA-Z\s]', '', tgt_title).strip()
        # If it is totally empty after cleaning, use a safe fallback
        if not tgt_title: 
            tgt_title = "an external document"

    # Clean up the predicate text
    predicate = str(attr.get('predicate', 'related to')).replace("_", " ")
    
    structured_fact = f"{src_title} {predicate} {tgt_title}."
    edge_lines.append(f"{idx}. {structured_fact}")

GRAPH_EDGE_CONTEXT = "\n".join(edge_lines)

print("Context successfully built!")

