import re

print("=" * 90)
print("TOP 10 RETRIEVED DOCUMENTS (No LLM)")
print("=" * 90)

# ----------------------------------------------------------
# 1. User Query & Configuration
# ----------------------------------------------------------
query = "Why is being a SQEP important in the context described in the document?"
TOP_K = 10
print(f"\nQuery: {query.strip()}\n")

# ----------------------------------------------------------
# 2. Extract Keywords (Using your proven math)
# ----------------------------------------------------------
STOPWORDS = {"how", "can", "a", "new", "be", "created", "in", "the", "what", "is", "of", "to", "and", "for", "on", "it", "does", "typically", "why"}

def get_keywords(text):
    tokens = set(re.findall(r'[a-z0-9]+', str(text).lower()))
    return tokens - STOPWORDS

query_keywords = get_keywords(query)

# ----------------------------------------------------------
# 3. Retrieve Top-K Candidates from Knowledge Graph (KG)
# ----------------------------------------------------------
candidates = []

for node, attr in KG.nodes(data=True):
    # Get title and content
    title = str(attr.get('title', ''))
    content = str(attr.get('content', ''))
    reference = str(attr.get('reference', 'No reference available'))
    
    # Calculate Keyword Overlap (Intersection)
    title_keywords = get_keywords(title)
    content_keywords = get_keywords(content)
    
    # Title matches are worth 5 points, Content matches are worth 1 point
    title_overlap = len(query_keywords.intersection(title_keywords)) * 5
    content_overlap = len(query_keywords.intersection(content_keywords)) * 1
    
    total_score = title_overlap + content_overlap
    
    if total_score > 0:
        candidates.append({
            "doc_id": node,
            "title": title,
            "content": content,
            "reference": reference,
            "score": float(total_score)
        })

# Sort by highest score first, then grab the Top K
candidates.sort(key=lambda x: x["score"], reverse=True)
top_candidates = candidates[:TOP_K]

# ----------------------------------------------------------
# 4. Display Retrieved Documents (From your PDF formatting)
# ----------------------------------------------------------
if len(top_candidates) == 0:
    print("No documents found for this query.")
else:
    for rank, candidate in enumerate(top_candidates, 1):
        print(f"\n{'-' * 90}")
        print(f" Rank      : {rank}")
        print(f" Doc ID    : {candidate['doc_id']}")
        print(f" Title     : {candidate['title']}")
        print(f" Reference : {candidate['reference']}")
        print(f" Score     : {candidate['score']:.2f}")
        print(f"{'-' * 90}")
        print(f" Content   :")
        
        c_text = candidate["content"]
        print(f" {c_text[:2000]}")
        if len(c_text) > 2000:
            print(f"   ... [truncated, total {len(c_text)} chars]")
        print()

print("=" * 90)
print(f"Total Retrieved: {len(top_candidates)} documents")
print("=" * 90)
