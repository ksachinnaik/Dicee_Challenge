# 2. Keyword Extraction (Your proven math)
# ----------------------------------------------------------
STOPWORDS = {"how", "can", "a", "new", "be", "created", "in", "the", "what",
             "is", "of", "to", "and", "for", "on", "it", "does", "typically",
             "why", "if", "i", "after"}

def get_keywords(text):
    tokens = set(re.findall(r'[a-z0-9]+', str(text).lower()))
    return tokens - STOPWORDS

