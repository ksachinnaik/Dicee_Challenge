# 1. The User's Query (from the PDF example)
USER_QUERY = "How is MATLAB related to Turbine Engineering?"

print(f"User Query: {USER_QUERY}\n")

# ----------------------------------------------------------
# 2. Query Understanding & Find Start Node
# ----------------------------------------------------------
# In production, an LLM extracts these. For now, we do exact entity matching.
query_lower = USER_QUERY.lower()
start_nodes = []

# Scan our graph to find nodes mentioned in the query
for node, attr in KG.nodes(data=True):
    node_title = str(attr.get('title', '')).lower()
    if node_title and node_title in query_lower:
        start_nodes.append(node)

print(f"Entities Detected in Query : {len(start_nodes)}")
for n in start_nodes:
    print(f" - {KG.nodes[n].get('title', n)}")
print()

# ----------------------------------------------------------
# 3. Graph Traversal (1-Hop and 2-Hop)
# ----------------------------------------------------------
retrieved_edges = []
visited_edges = set()

print("Starting Graph Traversal...")

# Hop through the graph starting from our matched entities
for start_node in start_nodes:
    
    # 1-Hop Neighbors (Direct connections)
    for neighbor in KG.successors(start_node):
        edge_tuple = (start_node, neighbor)
        if edge_tuple not in visited_edges:
            edge_data = KG.get_edge_data(start_node, neighbor)
            retrieved_edges.append((start_node, neighbor, edge_data))
            visited_edges.add(edge_tuple)
        
        # 2-Hop Neighbors (Connections of connections)
        for second_neighbor in KG.successors(neighbor):
            edge_tuple_2 = (neighbor, second_neighbor)
            if edge_tuple_2 not in visited_edges:
                edge_data_2 = KG.get_edge_data(neighbor, second_neighbor)
                retrieved_edges.append((neighbor, second_neighbor, edge_data_2))
                visited_edges.add(edge_tuple_2)

print(f"Traversal Complete! Retrieved {len(retrieved_edges)} semantic relationships.\n")

# ----------------------------------------------------------
# 4. Show Retrieved Raw Paths
# ----------------------------------------------------------
print("-" * 80)
print("RAW RETRIEVED GRAPH PATHS")
print("-" * 80)

