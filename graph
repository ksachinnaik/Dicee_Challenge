# Draw Node Labels
nx.draw_networkx_labels(
    KG, 
    pos, 
    labels=node_labels, 
    font_size=9, 
    font_weight="bold"
)

# Draw Edges
nx.draw_networkx_edges(
    KG, 
    pos, 
    arrows=True, 
    arrowsize=20, 
    width=2,
    edge_color="gray",
    alpha=0.7,
    connectionstyle="arc3,rad=0.1" # slight curve so bidirectional edges don't overlap
)

# Draw Predicate Labels
nx.draw_networkx_edge_labels(
    KG, 
    pos, 
    edge_labels=edge_labels, 
    font_size=9, 
    font_color="darkred",
    bbox=dict(alpha=0.8, edgecolor='none', facecolor='white') # Make labels pop
)

plt.title("Semantic Knowledge Graph", fontsize=24, fontweight="bold", pad=20)
plt.axis("off")
plt.tight_layout()

# Render the graph!
plt.show()


