from pyspark.sql import functions as F

print("=" * 80)
print("RDF TRIPLE GENERATION (Cell 12)")
print("=" * 80)

# ----------------------------------------------------------
# 1. Filter and Deduplicate Semantic Records
# ----------------------------------------------------------
# We use the rdf_df generated at the end of Cell 11
validated_rdf_df = (
    rdf_df
    # 1. Skip incomplete triples
    .filter(
        F.col("subject_id").isNotNull() & (F.col("subject_id") != "") &
        F.col("predicate").isNotNull() & (F.col("predicate") != "") &
        F.col("object_id").isNotNull() & (F.col("object_id") != "")
    )
    # 2. Skip self-loops (where a document links to itself)
    .filter(F.col("subject_id") != F.col("object_id"))
    
    # 3. Deduplicate based on the core RDF triple keys
    .dropDuplicates(["subject_id", "predicate", "object_id"])
    
    # 4. Standardize column names as per your requirement
    .select(
        F.col("subject_id").alias("subject"),         # XML Reference (Node Key)
        F.col("predicate"),                           # Semantic Relationship
        F.col("object_id").alias("object"),           # XML Reference (Node Key)
        F.col("subject").alias("subject_title"),      # Title (Display)
        F.col("object").alias("object_title"),        # Title (Display)
        F.col("sentence"),
        F.col("link_type")
    )
)

# ----------------------------------------------------------
# 2. Calculate Predicate Distribution
# ----------------------------------------------------------
# Spark will group and count the predicates instantly
predicate_distribution = (
    validated_rdf_df
    .groupBy("predicate")
    .count()
    .orderBy(F.desc("count"))
)

# ----------------------------------------------------------
# 3. Summary
# ----------------------------------------------------------
print()
print("=" * 80)
print("RDF TRIPLE SUMMARY")
print("=" * 80)

# Count the DataFrames
input_count = rdf_df.count()
output_count = validated_rdf_df.count()

print(f"Semantic Records (input) : {input_count}")
print(f"Unique RDF Triples       : {output_count}")

print()
print("-" * 80)
print("PREDICATE DISTRIBUTION")
print("-" * 80)

# Display the predicate distribution nicely
for row in predicate_distribution.collect():
    print(f"{row['predicate']:<25} : {row['count']}")

print()
print("-" * 80)
print("SAMPLE RDF TRIPLES (Reference-based)")
print("-" * 80)

# Show a few sample triples to verify the layout
for row in validated_rdf_df.limit(10).collect():
    print(f" Subject   : {row['subject']}")
    print(f" Predicate : {row['predicate']}")
    print(f" Object    : {row['object']}")
    print(f" Display   : ({row['subject_title']}, {row['predicate']}, {row['object_title']})")
    print()

# View the final, fully clean Graph Table!
display(validated_rdf_df)
