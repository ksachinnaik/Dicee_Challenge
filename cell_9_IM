from pyspark.sql.types import StringType
from pyspark.sql import functions as F
from langchain_openai import ChatOpenAI

print("=" * 80)
print("SEMANTIC RELATIONSHIP EXTRACTION (LLM)")
print("=" * 80)

# ----------------------------------------------------------
# 1. Capture Driver Variables for Worker Nodes
# ----------------------------------------------------------
# Spark workers need these variables, so we capture them here.
driver_token = DATABRICKS_TOKEN
driver_deployment = DEPLOYMENT_NAME
driver_base_url = "https://adb-395568870984.4.azuredatabricks.net/serving-endpoints"

# ----------------------------------------------------------
# 2. Define the LLM Extraction Logic
# ----------------------------------------------------------
def extract_predicate(source_title, display_text, clean_sentence):
    # Fallback if sentence is empty
    if not clean_sentence:
        return "mentions"
        
    try:
        # Initialize LLM directly inside the worker task
        worker_llm = ChatOpenAI(
            model=driver_deployment,
            base_url=driver_base_url,
            api_key=driver_token,
            temperature=0
        )
        
        # Design a strict prompt for Graph Extraction
        prompt = f"""You are an expert at extracting semantic relationships for a Knowledge Graph.
Given a Source Entity, a Target Entity, and a Sentence, extract the semantic relationship (Predicate) connecting them.
The Predicate should be a short, concise snake_case phrase (e.g., 'within', 'depends_on', 'uses', 'part_of').
If no clear relationship is found, return 'mentions'.
Respond ONLY with the Predicate phrase. No quotes, no markdown, no other text.

Source: {source_title}
Target: {display_text}
Sentence: {clean_sentence}
Predicate:"""

        # Call the LLM
        response = worker_llm.invoke([("human", prompt)])
        predicate = response.content.strip().lower()
        
        # Clean up any accidental punctuation returned by the LLM
        predicate = predicate.replace("'", "").replace('"', "").replace(" ", "_")
        
        return predicate
        
    except Exception as e:
        # If the LLM endpoint fails/times out, default to a generic edge
        return "mentions"

# Register the PySpark UDF
extract_predicate_udf = F.udf(extract_predicate, StringType())

# ----------------------------------------------------------
# 3. Apply LLM UDF Across the Spark Cluster
# ----------------------------------------------------------
# This will process in parallel across your cluster!
rdf_df = (
    sentences_df
    .withColumn(
        "predicate",
        extract_predicate_udf(
            F.col("source_title"),
            F.col("display_text"),
            F.col("sentence")
        )
    )
)

print(f"Total Predicates Extracted : {rdf_df.count()}")
print()

# View the final Subject, Predicate, Object structure!
display(
    rdf_df.select("source_title", "predicate", "display_text", "sentence")
)
